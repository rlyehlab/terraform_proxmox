# https://github.com/github/gitignore/blob/main/Terraform.gitignore

# Local Terraform working directories (all layers under live/)
.terraform/

# State files
*.tfstate
*.tfstate.*
terraform.tfstate.remote.json

# Crash logs
crash.log
crash.*.log
*.log

# Secrets — never commit credentials or tokens
*env.secrets.auto.tfvars
live/*/env.secrets.auto.tfvars
create_template/**/config.env

# Override files (local only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock files (regenerated by terraform init)
*.terraform.tfstate.lock.info
*.terraform.lock.hcl

# Plan outputs
*.tfplan
tfplan
plan.tfplan

# CLI config
.terraformrc
terraform.rc

# Cloud images — download locally, do not commit (600MB+)
create_template/**/*.img
create_template/**/*.qcow2

# OS / editor noise
.DS_Store
.idea/
.vscode/
