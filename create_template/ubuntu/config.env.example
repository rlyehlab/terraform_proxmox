# Copy to config.env and adjust for your Proxmox node.
# Run on the Proxmox host (or any host with qm + network access to it).

# Preferred VM ID (must match template_map.ubuntu when this ID is free).
# If VM/template 6009 already exists, the script keeps it and uses the next free ID.
VMID=6009
VM_NAME="ubuntu-cloudinit-template"

# Ubuntu cloud image (20.04 Focal LTS). Other examples:
#   22.04: https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img
#   24.04: https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img
IMAGE_URL="https://cloud-images.ubuntu.com/focal/current/focal-server-cloudimg-amd64.img"
IMAGE_FILE="focal-server-cloudimg-amd64.img"

# Optional: absolute path to a pre-downloaded image (overrides auto-discovery)
# IMAGE_PATH="/root/create_template/ubuntu/focal-server-cloudimg-amd64.img"

# Proxmox resources
BRIDGE="vmbr0"
MEMORY=2048
CORES=2

# Where the imported disk lives (matches Terraform module default datastore_id)
DISK_STORAGE="tank"

# Cloud-init drive (matches Terraform initialization_datastore_id)
CLOUDINIT_STORAGE="local-lvm"

# Grow root disk on the template so clones have room before Terraform resize (GB).
# Cloud images ship ~2–3 GB; 8 GB is a safe minimum for apt upgrades.
TEMPLATE_DISK_SIZE="+6G"

# Extra packages baked into the image (space-separated)
EXTRA_PACKAGES="qemu-guest-agent"

# Run virt-sysprep before templating (resets machine-id; do not boot the VM first)
RUN_VIRT_SYSPREP=true
